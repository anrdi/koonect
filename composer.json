{
  "name": "koonect/koonect-fr",
  "description": "Koonect — Journal en ligne professionnel",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "phpmailer/phpmailer": "^6.9",
    "ext-pdo": "*",
    "ext-gd": "*",
    "ext-mbstring": "*",
    "ext-openssl": "*",
    "ext-json": "*",
    "ext-fileinfo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Koonect\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Koonect\\Tests\\": "tests/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {}
  },
  "scripts": {
    "post-install-cmd": [
      "@php -r \"if(!file_exists('.env')){copy('.env.example','.env');echo 'Fichier .env créé — pensez à le configurer.' . PHP_EOL;}\""
    ]
  }
}
