# Koonect - Variables d'environnement
# Copier en .env et compléter les valeurs

APP_NAME=Koonect
APP_URL=https://koonect.fr
APP_ENV=production
APP_DEBUG=false
APP_KEY=

DB_HOST=localhost
DB_PORT=3306
DB_NAME=koonect_db
DB_USER=koonect_user
DB_PASS=

SMTP_HOST=mail.koonect.fr
SMTP_PORT=587
SMTP_USER=noreply@koonect.fr
SMTP_PASS=
SMTP_FROM_NAME=Koonect
SMTP_FROM_EMAIL=noreply@koonect.fr

SESSION_LIFETIME=3600
SESSION_DOMAIN=.koonect.fr

UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=/storage/uploads

CACHE_DRIVER=file
CACHE_TTL=3600

# Cloudflare Turnstile
CF_SITE_KEY=
CF_PRIVATE_KEY=

TOTP_ISSUER=Koonect

LOG_LEVEL=error
LOG_PATH=/storage/logs

